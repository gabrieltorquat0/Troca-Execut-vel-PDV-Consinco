  object QueryPDVs: TFDQuery
    Connection = FDConnection1
    SQL.Strings = (
      'SELECT nroempresa,'
      '       nrocheckout,'
      '       ip,'
      '       so,'
      '       versaoaplicacao'
      'FROM ('
      '    SELECT b.nroempresa,'
      '           b.nrocheckout,'
      '           b.ip,'
      '           b.so,'
      '           a.versaoaplicacao,'
      '           ROW_NUMBER() OVER ('
      '               PARTITION BY a.nroempresa, a.nrocheckout'
      '               ORDER BY a.seqdocto DESC'
      '           ) rn'
      '    FROM tb_docto a'
      '    JOIN tb_checkout b'
      '      ON a.nroempresa = b.nroempresa'
      '     AND a.nrocheckout = b.nrocheckout'
      '    WHERE a.seqdocto < 1000000000'
      ')'
      'WHERE rn = 1'
      'order by 1,2;')
