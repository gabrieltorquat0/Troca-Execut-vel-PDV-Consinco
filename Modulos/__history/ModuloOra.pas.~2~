// conectar banco oracle
procedure TDmOra.ConectarOracle(
  const ADatabase, AUsuario, ASenha: string
);
begin
  FDConnection1.Close;
  FDConnection1.Params.Clear;

  if not Assigned(FOracleDriver) then
    FOracleDriver := TFDPhysOracleDriverLink.Create(Self);

  FDConnection1.DriverName := 'Ora';
  FDConnection1.Params.Database := ADatabase;
  FDConnection1.Params.UserName := AUsuario;
  FDConnection1.Params.Password := ASenha;
  FDConnection1.Params.Values['CharacterSet'] := 'UTF8';

  FDConnection1.LoginPrompt := False;
  FDConnection1.Connected := True;
end;

// validar conexao ip
function DmOra.IPOnline(const AIP: string): Boolean;
var
  WSAData: TWSAData;
  Sock: TSocket;
  Addr: TSockAddrIn;
begin
  Result := False;

  if WSAStartup($0202, WSAData) <> 0 then Exit;

  try
    Sock := socket(AF_INET, SOCK_STREAM, IPPROTO_TCP);
    if Sock = INVALID_SOCKET then Exit;

    Addr.sin_family := AF_INET;
    Addr.sin_port := htons(3306);
    Addr.sin_addr.S_addr := inet_addr(PAnsiChar(AnsiString(AIP)));

    if connect(Sock, Addr, SizeOf(Addr)) = 0 then
      Result := True;

    closesocket(Sock);
  finally
    WSACleanup;
  end;
end;

